+// ─── LESSON 3: Pub/Subscribe ──────────────────────────────────────────────────
+function PubSubLesson({ meta }) {
+  const STEPS = 4;
+  const [stage, setStage] = useState(0);
+  const advance = useCallback(() => setStage(s => (s >= STEPS ? 0 : s + 1)), []);
+  const goBack  = useCallback(() => setStage(s => (s > 0 ? s - 1 : 0)), []);
