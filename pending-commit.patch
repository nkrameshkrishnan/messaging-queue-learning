+# Lesson 02 – Traffic Routing: DestinationRule
+# Apply BEFORE VirtualService.
+# Apply: kubectl apply -f destination-rule.yaml
+---
+apiVersion: networking.istio.io/v1beta1
+kind: DestinationRule
+metadata:
+  name: backend
+  namespace: istio-demo
+spec:
+  host: backend   # Matches the Kubernetes Service name "backend"
+
+  # Default traffic policy applies to all subsets unless overridden
+  trafficPolicy:
+    loadBalancer:
+      simple: LEAST_REQUEST   # Options: ROUND_ROBIN, LEAST_REQUEST, RANDOM, PASSTHROUGH
+    connectionPool:
+      tcp:
+        maxConnections: 100
+        connectTimeout: 5s
+      http:
+        http1MaxPendingRequests: 100
+        http2MaxRequests: 1000
+        maxRequestsPerConnection: 100
+        idleTimeout: 60s
+    outlierDetection:
+      consecutive5xxErrors: 5
+      interval: 10s
+      baseEjectionTime: 30s
+      maxEjectionPercent: 50
+
+  # Subsets: named groups of pods selected by labels
+  subsets:
+    - name: v1
+      labels:
+        version: v1   # Selects pods with label version=v1
+      trafficPolicy:
+        loadBalancer:
+          simple: ROUND_ROBIN   # Override load balancer per subset
+
+    - name: v2
+      labels:
+        version: v2   # Selects pods with label version=v2
+      # Inherits default trafficPolicy if not overridden
+
+# ── After applying ────────────────────────────────────────────────────────────
+# kubectl get destinationrule -n istio-demo
+# istioctl analyze -n istio-demo   # validate config consistency
