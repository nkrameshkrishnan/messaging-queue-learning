+# Lesson 04 – Fault Injection
+# Test resilience by injecting delays and aborts without changing any app code.
+# Apply: kubectl apply -f fault-virtual-service.yaml
+# Remove: kubectl delete -f fault-virtual-service.yaml
+---
+# ── Scenario A: Delay fault (tests timeout handling) ─────────────────────────
+apiVersion: networking.istio.io/v1beta1
+kind: VirtualService
+metadata:
+  name: backend-fault-delay
+  namespace: istio-demo
+spec:
+  hosts:
+    - backend
+  http:
+    # Fault only fires for requests with the test header (production-safe)
+    - match:
+        - headers:
+            x-test-fault:
+              exact: "delay"
+      fault:
+        delay:
+          percentage:
+            value: 100.0   # 100% of matching requests get delayed
+          fixedDelay: 5s   # 5-second artificial delay before forwarding
+      route:
+        - destination:
+            host: backend
+            subset: v1
+      timeout: 3s   # If client timeout < fixedDelay, client sees a timeout error
+                    # This tests whether upstream callers handle slow responses
+
+    # Normal traffic (no fault header) routes normally
+    - route:
+        - destination:
+            host: backend
+            subset: v1
+---
+# ── Scenario B: Abort fault (tests retry and error handling) ─────────────────
+# kubectl apply -f - <<EOF
