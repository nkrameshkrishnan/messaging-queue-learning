+++ b/istio/07_mtls/peer-authentication.yaml
@@ -0,0 +1,76 @@
+# Lesson 07 – mTLS & PeerAuthentication
+# Enforce mutual TLS across the entire istio-demo namespace.
+# Migration path: PERMISSIVE → STRICT (never jump straight to STRICT in production)
+---
+# ── Stage 1: Permissive mode (safe for migration) ─────────────────────────────
+# Sidecars accept BOTH mTLS and plaintext. Existing clients continue working.
+# Apply first to validate everything still works before enforcing STRICT.
+apiVersion: security.istio.io/v1beta1
+kind: PeerAuthentication
+metadata:
+  name: default
+  namespace: istio-demo
+spec:
+  mtls:
+    mode: PERMISSIVE   # Change to STRICT once all clients have sidecars
+
+---
+# ── Stage 2: Strict mode (zero-trust, apply after validation) ────────────────
+# Uncomment and apply to enforce mTLS. All plaintext requests are rejected.
+#
+# apiVersion: security.istio.io/v1beta1
+# kind: PeerAuthentication
+# metadata:
+#   name: default
+#   namespace: istio-demo
+# spec:
+#   mtls:
+#     mode: STRICT
+
+---
+# ── Per-workload exception (legacy services without sidecars) ─────────────────
+# Keep one specific workload in PERMISSIVE while namespace is STRICT.
+# apiVersion: security.istio.io/v1beta1
+# kind: PeerAuthentication
+# metadata:
+#   name: legacy-permissive
+#   namespace: istio-demo
+# spec:
+#   selector:
+#     matchLabels:
+#       app: legacy-db-client   # Only this workload stays permissive
+#   mtls:
+#     mode: PERMISSIVE
+
+---
+# ── Mesh-wide mTLS (apply to ALL namespaces) ─────────────────────────────────
+# Applying to istio-system sets policy for the entire mesh.
+# apiVersion: security.istio.io/v1beta1
+# kind: PeerAuthentication
+# metadata:
+#   name: default
+#   namespace: istio-system   # ← istio-system scope = mesh-wide
+# spec:
+#   mtls:
+#     mode: STRICT
+
+# ── Verify mTLS status ────────────────────────────────────────────────────────
+# Check mTLS mode in Kiali (traffic graph shows 🔒 padlock icons when STRICT)
+#
+# Via istioctl:
+#   istioctl authn tls-check <pod-name>.<namespace> backend.istio-demo.svc.cluster.local
+#   Expected columns: STATUS=OK, SERVER=mTLS, CLIENT=mTLS
+#
+# Test that plaintext is rejected in STRICT mode:
+#   # Create a pod WITHOUT sidecar (in a non-injection namespace)
+#   kubectl run test --image=curlimages/curl:8.5.0 -n default -- sleep 3600
+#   kubectl exec test -n default -- curl http://backend.istio-demo:9090
+#   Expected: connection refused or SSL handshake error (plaintext blocked)
+#
+# Confirm mTLS is working (from a sidecar-injected pod):
+#   kubectl exec -n istio-demo <frontend-pod> -- curl http://backend:9090
+#   Expected: 200 OK (Envoy handles the mTLS handshake transparently)
+#
+# View certificate issued to a sidecar:
+#   istioctl proxy-config secret <frontend-pod> -n istio-demo
+#   Look for: CERT CHAIN, VALID CERT, expiry date
diff --git a/istio/08_authorization/authz-policy.yaml b/istio/08_authorization/authz-policy.yaml
new file mode 100644
index 0000000..9f057bc
--- /dev/null
+++ b/istio/08_authorization/authz-policy.yaml
@@ -0,0 +1,126 @@
+# Lesson 08 – Authorization Policy (Zero-Trust Access Control)
+# Control which services can talk to each other using SPIFFE identity.
+# Requires mTLS (lesson 07) to be active — principals are based on mTLS certs.
+---
+# ── Step 1: Default deny-all for the namespace ────────────────────────────────
+# Applying an empty AuthorizationPolicy with no rules creates a deny-all baseline.
+# This is the zero-trust starting point.
+apiVersion: security.istio.io/v1beta1
+kind: AuthorizationPolicy
+metadata:
+  name: deny-all
+  namespace: istio-demo
+spec:
+  {}   # Empty spec = deny ALL ingress traffic to all pods in this namespace
+
+---
+# ── Step 2: Allow frontend → backend ─────────────────────────────────────────
+# Only the frontend service account may call GET/POST on /api/* of backend.
+apiVersion: security.istio.io/v1beta1
+kind: AuthorizationPolicy
+metadata:
+  name: backend-allow-frontend
+  namespace: istio-demo
+spec:
+  selector:
+    matchLabels:
+      app: backend   # This policy applies to the backend pods
+
+  action: ALLOW
+
+  rules:
+    # Allow from frontend service account only
+    - from:
+        - source:
+            principals:
+              - "cluster.local/ns/istio-demo/sa/frontend-sa"   # SPIFFE identity
+      to:
+        - operation:
+            methods: ["GET", "POST"]
+            paths: ["/api/*", "/"]
+
+    # Allow health checks from anywhere (e.g., Kubernetes liveness probe)
+    - to:
+        - operation:
+            methods: ["GET"]
+            paths: ["/ready", "/live", "/healthz"]
+
+---
+# ── Allow ingress gateway → frontend ─────────────────────────────────────────
+apiVersion: security.istio.io/v1beta1
+kind: AuthorizationPolicy
+metadata:
+  name: frontend-allow-gateway
+  namespace: istio-demo
+spec:
+  selector:
+    matchLabels:
+      app: frontend
+
+  action: ALLOW
+
+  rules:
+    # Allow from the ingress gateway service account
+    - from:
+        - source:
+            principals:
+              - "cluster.local/ns/istio-system/sa/istio-ingressgateway-service-account"
+            namespaces:
+              - "istio-system"
+
+    # Allow health checks
+    - to:
+        - operation:
+            methods: ["GET"]
+            paths: ["/ready", "/live"]
+
+---
+# ── Explicit DENY: block a specific compromised service account ───────────────
+# DENY rules are evaluated BEFORE ALLOW rules.
+# apiVersion: security.istio.io/v1beta1
+# kind: AuthorizationPolicy
+# metadata:
+#   name: deny-attacker
+#   namespace: istio-demo
+# spec:
+#   action: DENY
+#   rules:
+#     - from:
+#         - source:
+#             principals:
+#               - "cluster.local/ns/default/sa/attacker"
+
+---
+# ── JWT-based end-user authorization ─────────────────────────────────────────
+# Combine service identity (mTLS) with JWT claims for user-level auth.
+# apiVersion: security.istio.io/v1beta1
+# kind: AuthorizationPolicy
+# metadata:
+#   name: backend-jwt-authz
+#   namespace: istio-demo
+# spec:
+#   selector:
+#     matchLabels:
+#       app: backend
+#   action: ALLOW
+#   rules:
+#     - from:
+#         - source:
+#             requestPrincipals: ["*"]   # Any authenticated JWT
+#       when:
+#         - key: request.auth.claims[role]
+#           values: ["admin", "editor"]  # Only users with these JWT roles
+
+# ── Test authorization ────────────────────────────────────────────────────────
+# Authorized call (frontend → backend):
+#   kubectl exec -n istio-demo <frontend-pod> -- curl http://backend:9090
+#   Expected: 200 OK
+#
+# Unauthorized call (from a pod without frontend-sa identity):
+#   kubectl run test --image=curlimages/curl -n istio-demo --restart=Never -- sleep 3600
+#   kubectl exec test -n istio-demo -- curl http://backend:9090
+#   Expected: RBAC: access denied (403)
+#
+# Check which policies are active:
+#   kubectl get authorizationpolicies -n istio-demo
+#   istioctl analyze -n istio-demo
